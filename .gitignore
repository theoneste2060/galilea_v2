# SQLite database (created at runtime; never commit data)
/data/*.sqlite
/data/*.sqlite-wal
/data/*.sqlite-shm

# User uploads (runtime content)
/uploads/*
!/uploads/.gitkeep
!/uploads/.htaccess

# Build artifacts / packages (never commit)
*.zip
*.deb

# Reference material / scratch (kept out of the deliverable)
/Desktop/
/Agriverse_may/

# OS / editor noise
.DS_Store
*.log
